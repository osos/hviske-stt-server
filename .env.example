# Model
HVISKE_MODEL_ID=syvai/hviske-v5.3

# Hugging Face token (required for gated models)
HF_TOKEN=

# Audio
HVISKE_TARGET_SR=16000
HVISKE_DEFAULT_LANGUAGE=da

# Generation
HVISKE_MAX_NEW_TOKENS=256
HVISKE_NUM_BEAMS=1
HVISKE_LENGTH_PENALTY=1.0
HVISKE_PUNCTUATION=true

# Chunking (constant memory for long audio)
HVISKE_CHUNK_SECONDS=30
HVISKE_CHUNK_OVERLAP_SECONDS=0

# Authentication (leave empty to disable)
HVISKE_API_KEY=

# Server
HVISKE_HOST=0.0.0.0
HVISKE_PORT=8000
HVISKE_LOG_LEVEL=info
